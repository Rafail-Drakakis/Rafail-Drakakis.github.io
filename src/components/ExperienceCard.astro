---
import type { ExperienceItem } from '../data/experience';

interface Props {
  item: ExperienceItem;
}

const { item } = Astro.props;
---

<article class="group relative rounded-xl border border-slate-800 bg-slate-900/50 p-6 transition-colors hover:border-slate-700">
  <div class="mb-1 flex flex-wrap items-start justify-between gap-2">
    <div>
      <h3 class="text-lg font-semibold text-white">{item.role}</h3>
      <p class="text-teal-400">{item.company}</p>
    </div>
    <span class="shrink-0 rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-400">
      {item.period}
    </span>
  </div>
  <p class="mb-4 text-sm text-slate-500">{item.location}</p>
  <ul class="space-y-2">
    {
      item.bullets.map((bullet) => (
        <li class="flex gap-2 text-sm text-slate-300">
          <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-teal-500" aria-hidden="true"></span>
          <span>{bullet}</span>
        </li>
      ))
    }
  </ul>
</article>
