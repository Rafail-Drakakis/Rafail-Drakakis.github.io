---
interface Props {
  id?: string;
  title: string;
  subtitle?: string;
}

const { id, title, subtitle } = Astro.props;
---

<section {id} class="px-6 py-16 md:py-20">
  <div class="mx-auto max-w-6xl">
    <div class="mb-10">
      <h2 class="text-2xl font-bold text-white md:text-3xl">{title}</h2>
      {subtitle && <p class="mt-2 text-slate-400">{subtitle}</p>}
      <div class="mt-4 h-1 w-16 rounded-full bg-gradient-to-r from-teal-500 to-cyan-400"></div>
    </div>
    <slot />
  </div>
</section>
