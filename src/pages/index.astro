---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import Section from '../components/Section.astro';
import ExperienceCard from '../components/ExperienceCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import SkillsGrid from '../components/SkillsGrid.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site';
import { experience } from '../data/experience';
import { featuredProjects, moreProjects } from '../data/projects';
import { education, awards } from '../data/education';

const workExperience = experience.filter((e) => e.type === 'work');
const volunteerExperience = experience.filter((e) => e.type === 'volunteer');
---

<BaseLayout>
  <Header />
  <main id="main">
    <Hero />

    <Section id="about" title="About">
      <p class="max-w-3xl text-lg leading-relaxed text-slate-300">
        {site.about}
      </p>
    </Section>

    <Section id="experience" title="Experience" subtitle="Professional roles and contributions">
      <div class="space-y-6">
        {workExperience.map((item) => <ExperienceCard item={item} />)}
      </div>
    </Section>

    <Section title="Volunteering" subtitle="Community and university involvement">
      <div class="space-y-6">
        {volunteerExperience.map((item) => <ExperienceCard item={item} />)}
      </div>
    </Section>

    <Section id="projects" title="Featured Projects" subtitle="Selected work across ML, web, and systems">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {featuredProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </Section>

    <Section title="More Projects" subtitle="Additional repositories and coursework">
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
        {moreProjects.map((project) => <ProjectCard project={project} compact />)}
      </div>
    </Section>

    <Section id="skills" title="Skills & Interests">
      <SkillsGrid />
    </Section>

    <Section id="education" title="Education & Awards">
      <div class="space-y-6">
        {
          education.map((item) => (
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <div class="mb-1 flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">{item.degree}</h3>
                  <p class="text-teal-400">{item.institution}</p>
                </div>
                <span class="shrink-0 rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-400">
                  {item.period}
                </span>
              </div>
              <p class="text-sm text-slate-500">{item.location}</p>
            </article>
          ))
        }
        {
          awards.map((award) => (
            <article class="rounded-xl border border-slate-800 bg-slate-900/50 p-6">
              <div class="mb-1 flex flex-wrap items-start justify-between gap-2">
                <div>
                  <h3 class="text-lg font-semibold text-white">{award.title}</h3>
                  <p class="text-teal-400">{award.subtitle}</p>
                </div>
                <span class="shrink-0 rounded-full bg-slate-800 px-3 py-1 text-xs text-slate-400">
                  {award.period}
                </span>
              </div>
              <p class="mt-3 text-sm text-slate-300">{award.description}</p>
            </article>
          ))
        }
      </div>
    </Section>
  </main>
  <Footer />
</BaseLayout>
